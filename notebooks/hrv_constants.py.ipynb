    "    'assertiveness_index',  # authoritative tone\n",
    "    'curiosity_index',      # curiosity / intrigue\n",
    "    'metaphor_density',     # metaphoric richness\n",
    "    'storytelling_index',   # narrative engagement\n",
    "    'active_voice_ratio',   # ratio of active vs passive sentences\n",
    "]"
   ]
