    "# Create comparison visualization\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n",
    "fig.suptitle('ResonanceOS Tier Comparison', fontsize=16)\n",
    "\n",
    "# Prepare data\n",
    "tiers = ['Tier 1', 'Tier 2', 'Tier 3']\n",
    "features_to_compare = ['lexical_density', 'emotional_valence', 'cadence_variability', 'abstraction_level']\n",
    "tier_data = {\n",
    "    'Tier 1': [tier1_features[f] for f in features_to_compare],\n",
    "    'Tier 2': [tier2_features[f] for f in features_to_compare],\n",
    "    'Tier 3': [tier3_features[f] for f in features_to_compare]\n",
    "}\n",
    "\n",
    "# Plot 1: Feature comparison\n",
    "ax1 = axes[0, 0]\n",
    "x = np.arange(len(features_to_compare))\n",
    "width = 0.25\n",
    "\n",
    "for i, tier in enumerate(tiers):\n",
    "    ax1.bar(x + i * width, tier_data[tier], width, label=tier)\n",
    "\n",
    "ax1.set_xlabel('Features')\n",
    "ax1.set_ylabel('Values')\n",
    "ax1.set_title('Feature Values by Tier')\n",
    "ax1.set_xticks(x + width)\n",
    "ax1.set_xticklabels([f.replace('_', '\\n') for f in features_to_compare])\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 2: Radar chart\n",
    "ax2 = axes[0, 1]\n",
    "angles = np.linspace(0, 2 * np.pi, len(features_to_compare), endpoint=False).tolist()\n",
    "angles += angles[:1]  # Complete the circle\n",
    "\n",
    "for tier in tiers:\n",
    "    values = tier_data[tier] + tier_data[tier][:1]  # Complete the circle\n",
    "    ax2.plot(angles, values, 'o-', label=tier, linewidth=2)\n",
    "    ax2.fill(angles, values, alpha=0.25)\n",
    "\n",
    "ax2.set_xticks(angles[:-1])\n",
    "ax2.set_xticklabels([f.replace('_', '\\n') for f in features_to_compare])\n",
    "ax2.set_ylim(0, 1)\n",
