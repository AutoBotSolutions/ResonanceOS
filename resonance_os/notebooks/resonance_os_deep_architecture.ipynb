n",
    "def estimate_memory_usage():\n",
    "    \"\"\"Estimate memory usage for different operations\"\"\"\n",
    "    \n",
    "    # Base memory usage (bytes)\n",
    "    base_usage = {\n",
    "        'resonance_vector': 10 * 8,  # 10 dimensions * 8 bytes per float\n",
    "        'profile_metadata': 1024,  # 1KB for metadata\n",
    "        'similarity_calculation': 100,  # Temporary storage\n",
    "    }\n",
    "    \n",
    "    # Usage for different corpus sizes\n",
    "    corpus_sizes = [1000, 10000, 100000, 1000000]  # words\n",
    "    \n",
    "    memory_estimates = {}\n",
    "    \n",
    "    for size in corpus_sizes:\n",
    "        estimates = {\n",
    "            'corpus_words': size,\n",
    "            'tier1_memory': size * 2 + sum(base_usage.values()),  # 2 bytes per word\n",
    "            'tier2_memory': size * 4 + sum(base_usage.values()),  # 4 bytes per word + spaCy overhead\n",
    "            'tier3_memory': size * 8 + sum(base_usage.values()) + 768 * 1000,  # 8 bytes + model\n",
    "        }\n",
    "        \n",
    "        # Convert to MB\n",
    "        for key in estimates:\n",
    "            if key != 'corpus_words':\n",
    "                estimates[key] = estimates[key] / (1024 * 1024)\n",
    "        \n",
    "        memory_estimates[f'{size:,}_words'] = estimates\n",
    "    \n",
    "    return memory_estimates\n",
    "\n",
    "# Generate memory estimates\n",
    "memory_data = estimate_memory_usage()\n",
    "\n",
    "# Create visualization\n",
    "fig, ax = plt.subplots(figsize=(12, 8))\n",
    "\n",
    "corpus_labels = list(memory_data.keys())\n",
    "tier1_memory = [data['tier1_memory'] for data in memory_data.values()]\n",
    "tier2_memory = [data['tier2_memory'] for data in memory_data.values()]\n",
    "tier3_memory = [data['tier3_memory'] for data in memory_data.values()]\n",
    "\n",
    "x = np.arange(len(corpus_labels))\n",
    "width = 0.25\n",
    "\n",
    "ax.bar(x - width, tier1_memory, width, label='Tier 1', alpha=0.7)\n",
    "ax.bar(x, tier2_memory, width, label='Tier 2', alpha=0.7)\n",
    "ax.bar(x + width, tier3_memory, width, label='Tier 3', alpha=0.7)\n",
    "\n",
    "ax.set_xlabel('Corpus Size')\n",
    "ax.set_ylabel('Memory Usage (MB)')\n",
    "ax.set_title('Memory Usage Estimation by Corpus Size and Tier')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels([label.replace('_words', ' words') for label in corpus_labels])\n",
    "ax.legend()\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    "# Add value labels on bars\n",
    "for i, (t1, t2, t3) in enumerate(zip(tier1_memory, tier2_memory, tier3_memory)):\n",
    "    ax.text(i - width, t1 + 0.5, f'{t1:.1f}', ha='center', va='bottom', fontsize=8)\n",
    "    ax.text(i, t2 + 0.5, f'{t2:.1f}', ha='center', va='bottom', fontsize=8)\n",
    "    ax.text(i + width, t3 + 0.5, f'{t3:.1f}', ha='center', va='bottom', fontsize=8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Print detailed estimates\n",
    "print(\"Memory Usage Estimation:\")\n",
    "print(\"=\" * 40)\n",
    "\n",
    "for corpus_size, data in memory_data.items():\n",
    "    print(f\"\\n{corpus_size.replace('_', ' ')}:\")\n",
    "    print(f\"  Tier 1: {data['tier1_memory']:.2f} MB\")\n",
    "    print(f\"  Tier 2: {data['tier2_memory']:.2f} MB\")\n",
    "    print(f\"  Tier 3: {data['tier3_memory']:.2f} MB\")"
