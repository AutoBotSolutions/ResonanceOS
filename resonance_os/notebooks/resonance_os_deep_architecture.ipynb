    "## 5. Real-Time Feedback Simulation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class FeedbackSimulator:\n",
    "    \"\"\"Simulate real-time feedback during text generation\"\"\"\n",
    "    \n",
    "    def __init__(self, target_vector: np.ndarray):\n",
    "        self.target_vector = target_vector\n",
    "       .similarity_history = []\n",
    "        self.drift_history = []\n",
    "        self.correction_history = []\n",
    "    \n",
    "    def simulate_generation_step(self, step: int, noise_level: float = 0.1) -> Dict:\n",
    "        \"\"\"Simulate one generation step with feedback\"\"\"\n",
    "        \n",
    "        # Generate current vector with noise\n",
    "        noise = np.random.normal(0, noise_level, len(self.target_vector))\n",
    "        current_vector = self.target_vector + noise\n",
    "        current_vector = np.clip(current_vector, 0, 1)  # Keep in valid range\n",
    "        \n",
    "        # Calculate similarity\n",
    "        similarity = cosine_similarity(current_vector, self.target_vector)\n",
    "        self.similarity_history.append(similarity)\n",
    "        \n",
    "        # Calculate drift\n",
    "        if len(self.similarity_history) > 1:\n",
    "            drift = calculate_drift_rate(self.similarity_history)\n",
    "            self.drift_history.append(drift)\n",
    "        else:\n",
    "            drift = 0.0\n",
    "        \n",
    "        # Determine if correction needed\n",
    "        threshold = 0.92\n",
    "        correction_needed = similarity < threshold\n",
    "        \n",
    "        if correction_needed:\n",
    "            # Simulate correction\n",
    "            correction_strength = (threshold - similarity) / threshold\n",
    "            self.correction_history.append(correction_strength)\n",
    "            \n",
    "            # Apply correction (reduce noise)\n",
    "            corrected_vector = self.target_vector + np.random.normal(0, noise_level * 0.5, len(self.target_vector))\n",
    "            corrected_vector = np.clip(corrected_vector, 0, 1)\n",
    "            similarity = cosine_similarity(corrected_vector, self.target_vector)\n",
    "        else:\n",
    "            correction_strength = 0.0\n",
    "        \n",
    "        return {\n",
    "            'step': step,\n",
    "            'similarity': similarity,\n",
    "            'drift': drift,\n",
    "            'correction_needed': correction_needed,\n",
    "            'correction_strength': correction_strength,\n",
    "            'vector': current_vector.tolist()\n",
    "        }\n",
    "\n",
    "# Run simulation\n",
    "target_vector = np.array([0.8, 0.7, 0.6, 0.7, 0.8, 0.6, 0.7, 0.6, 0.7, 0.6])\n",
    "simulator = FeedbackSimulator(target_vector)\n",
    "\n",
    "# Simulate 20 generation steps\n",
    "results = []\n",
    "for step in range(20):\n",
    "    # Increase noise over time to simulate drift\n",
    "    noise_level = 0.05 + (step * 0.01)\n",
    "    result = simulator.simulate_generation_step(step, noise_level)\n",
    "    results.append(result)\n",
    "\n",
    "# Visualization\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n",
    "fig.suptitle('Real-Time Feedback Simulation', fontsize=16)\n",
    "\n",
    "# Plot 1: Similarity over time\n",
    "ax1 = axes[0, 0]\n",
    "steps = [r['step'] for r in results]\n",
    "similarities = [r['similarity'] for r in results]\n",
    "corrections = [r['step'] for r in results if r['correction_needed']]\n",
    "\n",
    "ax1.plot(steps, similarities, 'b-', linewidth=2, label='Similarity')\n",
    "ax1.axhline(y=0.92, color='r', linestyle='--', label='Threshold')\n",
    "ax1.scatter(corrections, [results[i]['similarity'] for i, r in enumerate(results) if r['correction_needed']], \n",
    "           color='red', s=100, marker='x', label='Corrections')\n",
    "ax1.set_xlabel('Generation Step')\n",
    "ax1.set_ylabel('Similarity Score')\n",
    "ax1.set_title('Similarity with Real-Time Corrections')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 2: Drift rate\n",
    "ax2 = axes[0, 1]\n",
    "drifts = [r['drift'] for r in results if r['drift'] > 0]\n",
    "drift_steps = [r['step'] for r in results if r['drift'] > 0]\n",
    "\n",
    "if drifts:\n",
    "    ax2.plot(drift_steps, drifts, 'g-', linewidth=2)\n",
    "    ax2.axhline(y=0.02, color='r', linestyle='--', label='Drift Threshold')\n",
    "    ax2.set_xlabel('Generation Step')\n",
    "    ax2.set_ylabel('Drift Rate')\n",
    "    ax2.set_title('Drift Rate Over Time')\n",
    "    ax2.legend()\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 3: Vector deviation heatmap\n",
    "ax3 = axes[1, 0]\n",
    "deviation_matrix = np.zeros((len(results), len(RESONANCE_DIMENSIONS)))\n",
    "for i, result in enumerate(results):\n",
    "    vector = np.array(result['vector'])\n",
    "    deviation = np.abs(vector - target_vector)\n",
    "    deviation_matrix[i] = deviation\n",
    "\n",
    "im = ax3.imshow(deviation_matrix.T, cmap='YlOrRd', aspect='auto')\n",
    "ax3.set_xlabel('Generation Step')\n",
    "ax3.set_ylabel('Resonance Dimensions')\n",
    "ax3.set_title('Vector Deviation Heatmap')\n",
    "ax3.set_yticks(range(len(RESONANCE_DIMENSIONS)))\n",
    "ax3.set_yticklabels([d.replace('_', '\\n') for d in RESONANCE_DIMENSIONS])\n",
    "plt.colorbar(im, ax=ax3, label='Deviation')\n",
    "\n",
    "# Plot 4: Correction statistics\n",
    "ax4 = axes[1, 1]\n",
    "correction_strengths = [r['correction_strength'] for r in results if r['correction_needed']]\n",
    "correction_steps = [r['step'] for r in results if r['correction_needed']]\n",
    "\n",
    "if correction_strengths:\n",
    "    ax4.bar(correction_steps, correction_strengths, color='orange', alpha=0.7)\n",
    "    ax4.set_xlabel('Generation Step')\n",
    "    ax4.set_ylabel('Correction Strength')\n",
    "    ax4.set_title('Correction Events')\n",
    "    ax4.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Print summary statistics\n",
    "print(f\"\\nSimulation Summary:\")\n",
    "print(f\"Total steps: {len(results)}\")\n",
    "print(f\"Corrections made: {len(corrections)}\")\n",
    "print(f\"Final similarity: {similarities[-1]:.3f}\")\n",
    "print(f\"Average similarity: {np.mean(similarities):.3f}\")\n",
    "print(f\"Max drift rate: {max(drifts) if drifts else 0:.4f}\")"
   ]
