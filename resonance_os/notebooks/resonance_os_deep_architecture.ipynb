    "## 6. Evolution Algorithm Simulation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class EvolutionSimulator:\n",
    "    \"\"\"Simulate genetic algorithm evolution for profile optimization\"\"\"\n",
    "    \n",
    "    def __init__(self, target_vector: np.ndarray, population_size: int = 20):\n",
    "        self.target_vector = target_vector\n",
    "        self.population_size = population_size\n",
    "        self.dimensions = len(target_vector)\n",
    "        self.population = self._initialize_population()\n",
    "        self.fitness_history = []\n",
    "        \n",
    "    def _initialize_population(self) -> List[np.ndarray]:\n",
    "        \"\"\"Initialize random population\"\"\"\n",
    "        population = []\n",
    "        for _ in range(self.population_size):\n",
    "            individual = np.random.random(self.dimensions)\n",
    "            population.append(individual)\n",
    "        return population\n",
    "    \n",
    "    def fitness_function(self, individual: np.ndarray) -> float:\n",
    "        \"\"\"Calculate fitness for an individual\"\"\"\n",
    "        # Fitness based on similarity to target\n",
    "        similarity = cosine_similarity(individual, self.target_vector)\n",
    "        \n",
    "        # Bonus for balanced vector\n",
    "        balance = 1.0 - np.std(individual)\n",
    "        \n",
    "        # Combined fitness\n",
    "        fitness = (similarity * 0.7) + (balance * 0.3)\n",
    "        return fitness\n",
    "    \n",
    "    def selection(self, fitness_scores: List[float]) -> List[int]:\n",
    "        \"\"\"Tournament selection\"\"\"\n",
    "        selected = []\n",
    "        tournament_size = 3\n",
    "        \n",
    "        for _ in range(self.population_size):\n",
    "            tournament_indices = np.random.choice(len(self.population), tournament_size, replace=False)\n",
    "            tournament_fitness = [fitness_scores[i] for i in tournament_indices]\n",
    "            winner_index = tournament_indices[np.argmax(tournament_fitness)]\n",
    "            selected.append(winner_index)\n",
    "        \n",
    "        return selected\n",
    "    \n",
    "    def crossover(self, parent1: np.ndarray, parent2: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"Uniform crossover\"\"\"\n",
    "        child = np.zeros(self.dimensions)\n",
    "        for i in range(self.dimensions):\n",
    "            child[i] = parent1[i] if np.random.random() < 0.5 else parent2[i]\n",
    "        return child\n",
    "    \n",
    "    def mutation(self, individual: np.ndarray, mutation_rate: float = 0.1) -> np.ndarray:\n",
    "        \"\"\"Gaussian mutation\"\"\"\n",
    "        mutated = individual.copy()\n",
    "        for i in range(self.dimensions):\n",
    "            if np.random.random() < mutation_rate:\n",
    "                mutated[i] += np.random.normal(0, 0.1)\n",
    "                mutated[i] = np.clip(mutated[i], 0, 1)\n",
    "        return mutated\n",
    "    \n",
    "    def evolve_generation(self, mutation_rate: float = 0.1) -> Dict:\n",
    "        \"\"\"Evolve one generation\"\"\"\n",
    "        \n",
    "        # Calculate fitness\n",
    "        fitness_scores = [self.fitness_function(ind) for ind in self.population]\n",
    "        \n",
    "        # Track best fitness\n",
    "        best_fitness = max(fitness_scores)\n",
    "        avg_fitness = np.mean(fitness_scores)\n",
    "        self.fitness_history.append(best_fitness)\n",
    "        \n",
    "        # Selection\n",
    "        selected_indices = self.selection(fitness_scores)\n",
    "        \n",
    "        # Create new population\n",
    "        new_population = []\n",
    "        \n",
    "        # Keep best individual (elitism)\n",
    "        best_index = np.argmax(fitness_scores)\n",
    "        new_population.append(self.population[best_index].copy())\n",
    "        \n",
    "        # Generate offspring\n",
    "        while len(new_population) < self.population_size:\n",
    "            parent1_idx = np.random.choice(selected_indices)\n",
    "            parent2_idx = np.random.choice(selected_indices)\n",
    "            \n",
    "            child = self.crossover(self.population[parent1_idx], self.population[parent2_idx])\n",
    "            child = self.mutation(child, mutation_rate)\n",
    "            new_population.append(child)\n",
    "        \n",
    "        self.population = new_population\n",
    "        \n",
    "        return {\n",
    "            'best_fitness': best_fitness,\n",
    "            'avg_fitness': avg_fitness,\n",
    "            'best_individual': self.population[0].tolist()\n",
    "        }\n",
    "\n",
    "# Run evolution simulation\n",
    "target_vector = np.array([0.8, 0.7, 0.6, 0.7, 0.8, 0.6, 0.7, 0.6, 0.7, 0.6])\n",
    "evolver = EvolutionSimulator(target_vector, population_size=30)\n",
    "\n",
    "# Evolve for 50 generations\n",
    "generations = 50\n",
    "evolution_results = []\n",
    "\n",
    "for generation in range(generations):\n",
    "    # Decrease mutation rate over time\n",
    "    mutation_rate = 0.2 * (1 - generation / generations)\n",
    "    result = evolver.evolve_generation(mutation_rate)\n",
    "    result['generation'] = generation\n",
    "    evolution_results.append(result)\n",
    "\n",
    "# Visualization\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n",
    "fig.suptitle('Genetic Algorithm Evolution', fontsize=16)\n",
    "\n",
    "# Plot 1: Fitness over generations\n",
    "ax1 = axes[0, 0]\n",
    "generations_list = [r['generation'] for r in evolution_results]\n",
    "best_fitnesses = [r['best_fitness'] for r in evolution_results]\n",
    "avg_fitnesses = [r['avg_fitness'] for r in evolution_results]\n",
    "\n",
    "ax1.plot(generations_list, best_fitnesses, 'g-', linewidth=2, label='Best Fitness')\n",
    "ax1.plot(generations_list, avg_fitnesses, 'b--', linewidth=1, label='Average Fitness')\n",
    "ax1.set_xlabel('Generation')\n",
    "ax1.set_ylabel('Fitness')\n",
    "ax1.set_title('Fitness Evolution')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 2: Convergence analysis\n",
    "ax2 = axes[0, 1]\n",
    "improvements = []\n",
    "for i in range(1, len(best_fitnesses)):\n",
    "    improvement = best_fitnesses[i] - best_fitnesses[i-1]\n",
    "    improvements.append(improvement)\n",
    "\n",
    "ax2.plot(range(1, len(improvements)+1), improvements, 'r-', linewidth=1)\n",
    "ax2.axhline(y=0, color='k', linestyle='-', alpha=0.3)\n",
    "ax2.set_xlabel('Generation')\n",
    "ax2.set_ylabel('Fitness Improvement')\n",
    "ax2.set_title('Convergence Rate')\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 3: Final population distribution\n",
    "ax3 = axes[1, 0]\n",
    "final_fitnesses = [evolver.fitness_function(ind) for ind in evolver.population]\n",
    "ax3.hist(final_fitnesses, bins=15, alpha=0.7, color='purple', edgecolor='black')\n",
    "ax3.axvline(x=np.mean(final_fitnesses), color='red', linestyle='--', label=f'Mean: {np.mean(final_fitnesses):.3f}')\n",
    "ax3.set_xlabel('Fitness')\n",
    "ax3.set_ylabel('Count')\n",
    "ax3.set_title('Final Population Fitness Distribution')\n",
    "ax3.legend()\n",
    "ax3.grid(True, alpha=0.3)\n",
    "\n",
    "# Plot 4: Best individual vs target\n",
    "ax4 = axes[1, 1]\n",
    "best_individual = evolver.population[0]\n",
    "x_pos = np.arange(len(RESONANCE_DIMENSIONS))\n",
    "\n",
    "width = 0.35\n",
    "ax4.bar(x_pos - width/2, target_vector, width, label='Target', alpha=0.7)\n",
    "ax4.bar(x_pos + width/2, best_individual, width, label='Best Individual', alpha=0.7)\n",
    "\n",
    "ax4.set_xlabel('Dimensions')\n",
    "ax4.set_ylabel('Values')\n",
    "ax4.set_title('Target vs Best Individual')\n",
    "ax4.set_xticks(x_pos)\n",
    "ax4.set_xticklabels([d[:8] for d in RESONANCE_DIMENSIONS], rotation=45, ha='right')\n",
    "ax4.legend()\n",
    "ax4.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Print evolution summary\n",
    "print(f\"\\nEvolution Summary:\")\n",
    "print(f\"Generations: {generations}\")\n",
    "print(f\"Final best fitness: {best_fitnesses[-1]:.4f}\")\n",
    "print(f\"Initial best fitness: {best_fitnesses[0]:.4f}\")\n",
    "print(f\"Total improvement: {best_fitnesses[-1] - best_fitnesses[0]:.4f}\")\n",
    "print(f\"Final similarity to target: {cosine_similarity(best_individual, target_vector):.4f}\")"
   ]
