    "## 3. Progressive Complexity Architecture\n",
    "\n",
    "ResonanceOS implements three tiers of analysis complexity:"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 3.1 Tier 1: Lightweight Statistical Analysis\n",
    "\n",
    "Basic statistical features using TextBlob and regex patterns."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "from collections import Counter\n",
    "import statistics\n",
    "\n",
    "class Tier1Analyzer:\n",
    "    \"\"\"Lightweight statistical analysis\"\"\"\n",
    "    \n",
    "    def analyze_text(self, text: str) -> Dict[str, float]:\n",
    "        \"\"\"Analyze text using basic statistical methods\"\"\"\n",
    "        \n",
    "        # Basic text preprocessing\n",
    "        words = text.split()\n",
    "        sentences = re.split(r'[.!?]+', text)\n",
    "        sentences = [s.strip() for s in sentences if s.strip()]\n",
    "        \n",
    "        features = {}\n",
    "        \n",
    "        # Lexical density\n",
    "        content_words = [w for w in words if len(w) > 3 and w.isalpha()]\n",
    "        features['lexical_density'] = len(content_words) / max(len(words), 1)\n",
    "        \n",
    "        # Sentence length variability\n",
    "        sentence_lengths = [len(s.split()) for s in sentences]\n",
    "        if len(sentence_lengths) > 1:\n",
    "            features['cadence_variability'] = statistics.stdev(sentence_lengths) / max(statistics.mean(sentence_lengths), 1)\n",
    "        else:\n",
    "            features['cadence_variability'] = 0.0\n",
    "        \n",
    "        # Sentence entropy\n",
    "        length_distribution = Counter(sentence_lengths)\n",
    "        total_sentences = len(sentences)\n",
    "        if total_sentences > 1:\n",
    "            entropy = -sum((count/total_sentences) * np.log2(count/total_sentences) \n",
    "                          for count in length_distribution.values())\n",
    "            features['sentence_entropy'] = entropy / max(np.log2(len(length_distribution)), 1)\n",
    "        else:\n",
    "            features['sentence_entropy'] = 0.0\n",
    "        \n",
    "        # Metaphor frequency (simplified)\n",
    "        metaphor_patterns = [r'\\bis\\s+(a|the)\\s+\\w+\\s+of\\b', r'\\blike\\s+a\\s+\\w+\\b']\n",
    "        metaphor_count = sum(len(re.findall(pattern, text, re.IGNORECASE)) for pattern in metaphor_patterns)\n",
    "        features['metaphor_frequency'] = metaphor_count / max(len(words), 1)\n",
    "        \n",
    "        # Abstraction level (simplified)\n",
    "        abstract_words = {'concept', 'idea', 'theory', 'principle', 'system', 'framework'}\n",
    "        concrete_words = {'table', 'chair', 'house', 'car', 'computer', 'phone'}\n",
    "        \n",
    "        abstract_count = sum(1 for word in words if word.lower() in abstract_words)\n",
    "        concrete_count = sum(1 for word in words if word.lower() in concrete_words)\n",
    "        \n",
    "        total_relevant = abstract_count + concrete_count\n",
    "        features['abstraction_level'] = abstract_count / max(total_relevant, 1)\n",
    "        \n",
    "        # Fill remaining dimensions with defaults\n",
    "        defaults = {\n",
    "            'emotional_valence': 0.5,\n",
    "            'assertiveness_score': 0.5,\n",
    "            'rhythm_signature': 0.5,\n",
    "            'narrative_intensity_curve': 0.5,\n",
    "            'cognitive_load_index': 0.5\n",
    "        }\n",
    "        \n",
    "        for key, value in defaults.items():\n",
    "            features[key] = value\n",
    "        \n",
    "        return features\n",
    "\n",
    "# Test Tier 1 analysis\n",
    "analyzer_tier1 = Tier1Analyzer()\n",
    "sample_text = \"\"\"\n",
    "The concept of artificial intelligence represents a fundamental shift in how we approach \n",
    "problem-solving in the modern era. This technological framework enables systems to learn \n",
    "from data and make decisions that traditionally required human intelligence. The implications \n",
    "for society are profound and multifaceted.\n",
    "\"\"\"\n",
    "\n",
    "tier1_features = analyzer_tier1.analyze_text(sample_text)\n",
    "\n",
    "print(\"Tier 1 Analysis Results:\")\n",
    "for feature, value in tier1_features.items():\n",
    "    print(f\"{feature.replace('_', ' ').title()}: {value:.3f}\")"
   ]
  },
