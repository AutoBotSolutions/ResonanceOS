    "class MultiProfileSimulator:\n",
    "    \"\"\"Simulate switching between multiple profiles during generation\"\"\"\n",
    "    \n",
    "    def __init__(self, profiles: Dict[str, np.ndarray]):\n",
    "        self.profiles = profiles\n",
    "        self.profile_names = list(profiles.keys())\n",
    "        self.current_profile = None\n",
    "        self.switch_history = []\n",
    "        \n",
    "    def generate_with_switching(self, topic: str, num_paragraphs: int, switch_frequency: int = 3) -> Dict:\n",
    "        \"\"\"Generate text with profile switching\"\"\"\n",
    "        \n",
    "        content = []\n",
    "        profile_usage = []\n",
    "        similarities = []\n",
    "        \n",
    "        # Start with first profile\n",
    "        current_profile_name = self.profile_names[0]\n",
    "        self.current_profile = self.profiles[current_profile_name]\n",
    "        \n",
    "        for paragraph in range(num_paragraphs):\n",
    "            # Switch profile if needed\n",
    "            if paragraph > 0 and paragraph % switch_frequency == 0:\n",
    "                # Switch to next profile\n                current_index = self.profile_names.index(current_profile_name)\n",
    "                next_index = (current_index + 1) % len(self.profile_names)\n",
    "                current_profile_name = self.profile_names[next_index]\n",
    "                self.current_profile = self.profiles[current_profile_name]\n",
    "                \n",
    "                self.switch_history.append({\n",
    "                    'paragraph': paragraph,\n",
    "                    'from_profile': self.profile_names[current_index],\n",
    "                    'to_profile': current_profile_name\n",
    "                })\n",
    "            \n",
    "            # Simulate paragraph generation\n",
    "            paragraph_vector = self._simulate_paragraph_generation(current_profile_name)\n",
    "            similarity = cosine_similarity(paragraph_vector, self.current_profile)\n",
    "            \n",
    "            content.append(f\"Paragraph {paragraph + 1} using {current_profile_name}\")\n",
    "            profile_usage.append(current_profile_name)\n",
    "            similarities.append(similarity)\n",
    "        \n",
    "        return {\n",
    "            'content': content,\n",
    "            'profile_usage': profile_usage,\n",
    "            'similarities': similarities,\n",
    "            'switches': self.switch_history,\n",
    "            'final_profile': current_profile_name\n",
    "        }\n",
    "    \n",
    "    def _simulate_paragraph_generation(self, profile_name: str) -> np.ndarray:\n",
    "        \"\"\"Simulate paragraph generation for a profile\"\"\"\n",
    "        target_vector = self.profiles[profile_name]\n",
    "        noise = np.random.normal(0, 0.05, len(target_vector))\n",
    "        generated_vector = target_vector + noise\n",
    "        return np.clip(generated_vector, 0, 1)\n",
    "\n",
    "# Create multiple profiles\n",
    "profiles = {\n",
    "    'Technical': np.array([0.9, 0.3, 0.4, 0.6, 0.5, 0.8, 0.7, 0.4, 0.5, 0.8]),\n",
    "    'Creative': np.array([0.7, 0.8, 0.8, 0.7, 0.9, 0.6, 0.5, 0.8, 0.9, 0.6]),\n",
    "    'Professional': np.array([0.6, 0.5, 0.5, 0.5, 0.4, 0.5, 0.6, 0.5, 0.5, 0.5])\n",
    "}\n",
    "\n",
    "# Run multi-profile simulation\n",
    "simulator = MultiProfileSimulator(profiles)\n",
    "result = simulator.generate_with_switching(\n",
    "    topic=\"Artificial Intelligence Applications\",\n",
    "    num_paragraphs=12,\n",
    "    switch_frequency=3\n",
    ")\n",
    "\n",
    "# Visualization\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n",
    "fig.suptitle('Multi-Profile Switching Simulation', fontsize=16)\n",
    "\n",
    "# Plot 1: Profile usage timeline\n",
    "ax1 = axes[0, 0]\n",
    "paragraphs = range(1, len(result['profile_usage']) + 1)\n",
    "colors = {'Technical': 'blue', 'Creative': 'green', 'Professional': 'red'}\n",
    "\n",
    "for i, profile_name in enumerate(result['profile_usage']):\n",
    "    ax1.bar(i, 1, color=colors[profile_name], alpha=0.7)\n",
    "\n",
    "ax1.set_xlabel('Paragraph')\n",
    "ax1.set_ylabel('Profile')\n",
    "ax1.set_title('Profile Usage Timeline')\n",
    "ax1.set_yticks([])\n",
    "\n",
    "# Add profile legend\n",
    "legend_elements = [plt.Rectangle((0,0),1,1, facecolor=colors[name], alpha=0.7, label=name) \n",
    "                   for name in colors.keys()]\n",
    "ax1.legend(handles=legend_elements, loc='upper right')\n",
    "\n",
    "# Mark switch points\n",
    "for switch in result['switches']:\n",
    "    ax1.axvline(x=switch['paragraph'], color='black', linestyle='--', alpha=0.5)\n",
    "\n",
    "# Plot 2: Similarity scores\n",
    "ax2 = axes[0, 1]\n",
    "ax2.plot(paragraphs, result['similarities'], 'o-', linewidth=2, markersize=6)\n",
    "ax2.axhline(y=0.92, color='r', linestyle='--', label='Target Threshold')\n",
    "ax2.set_xlabel('Paragraph')\n",
    "ax2.set_ylabel('Similarity Score')\n",
    "ax2.set_title('Similarity Scores by Paragraph')\n",
    "ax2.legend()\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "# Mark switch points\n",
    "for switch in result['switches']:\n",
    "    ax2.axvline(x=switch['paragraph'], color='black', linestyle='--', alpha=0.5)\n",
    "\n",
    "# Plot 3: Profile similarity matrix\n",
    "ax3 = axes[1, 0]\n",
    "profile_names = list(profiles.keys())\n",
    "similarity_matrix = np.zeros((len(profile_names), len(profile_names)))\n",
    "\n",
    "for i, name1 in enumerate(profile_names):\n",
    "    for j, name2 in enumerate(profile_names):\n",
    "        similarity_matrix[i, j] = cosine_similarity(profiles[name1], profiles[name2])\n",
    "\n",
    "im = ax3.imshow(similarity_matrix, cmap='viridis', vmin=0, vmax=1)\n",
    "ax3.set_xticks(range(len(profile_names)))\n",
    "ax3.set_yticks(range(len(profile_names)))\n",
    "ax3.set_xticklabels(profile_names)\n",
    "ax3.set_yticklabels(profile_names)\n",
    "ax3.set_title('Profile Similarity Matrix')\n",
    "\n",
    "# Add similarity values\n",
    "for i in range(len(profile_names)):\n",
    "    for j in range(len(profile_names)):\n",
    "        ax3.text(j, i, f'{similarity_matrix[i, j]:.2f}', ha='center', va='center')\n",
