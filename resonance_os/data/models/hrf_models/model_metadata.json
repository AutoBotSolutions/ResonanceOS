{
  "model_info": {
    "name": "ResonanceOS HRF Model v1.0",
    "type": "statistical",
    "version": "1.0.0",
    "description": "Human Resonant Feedback model for predicting content engagement and resonance",
    "created_at": "2026-03-09T00:00:00Z",
    "updated_at": "2026-03-09T00:00:00Z",
    "status": "production",
    "framework": "python_standard_library"
  },
  "architecture": {
    "model_type": "statistical_feature_extraction",
    "input_features": [
      "sentence_length_variance",
      "sentiment_polarity",
      "sentiment_intensity",
      "lexical_diversity",
      "readability_score",
      "complexity_metrics"
    ],
    "output_dimensions": 1,
    "activation_functions": ["linear"],
    "normalization": "min_max_scaling"
  },
  "training": {
    "algorithm": "linear_regression_with_regularization",
    "training_dataset": "internal_corpus_v1",
    "training_samples": 10000,
    "validation_samples": 2000,
    "test_samples": 2000,
    "training_epochs": 100,
    "early_stopping": true,
    "patience": 10,
    "regularization": "l2",
    "regularization_strength": 0.01,
    "learning_rate": 0.001,
    "batch_size": 32,
    "optimizer": "adam"
  },
  "performance": {
    "validation_accuracy": 0.87,
    "test_accuracy": 0.85,
    "mean_squared_error": 0.023,
    "mean_absolute_error": 0.12,
    "r_squared": 0.78,
    "training_time_seconds": 45.2,
    "inference_time_ms": 2.3,
    "model_size_mb": 0.1
  },
  "features": {
    "sentence_variance": {
      "weight": 0.15,
      "description": "Variance in sentence lengths",
      "importance": "medium",
      "range": [0.0, 1.0]
    },
    "emotional_valence": {
      "weight": 0.20,
      "description": "Positive/negative sentiment balance",
      "importance": "high",
      "range": [-1.0, 1.0]
    },
    "emotional_intensity": {
      "weight": 0.15,
      "description": "Strength of emotional content",
      "importance": "medium",
      "range": [0.0, 1.0]
    },
    "assertiveness_index": {
      "weight": 0.10,
      "description": "Confidence and directness level",
      "importance": "low",
      "range": [0.0, 1.0]
    },
    "curiosity_index": {
      "weight": 0.10,
      "description": "Question and curiosity elements",
      "importance": "low",
      "range": [0.0, 1.0]
    },
    "metaphor_density": {
      "weight": 0.08,
      "description": "Metaphorical language usage",
      "importance": "low",
      "range": [0.0, 1.0]
    },
    "storytelling_index": {
      "weight": 0.12,
      "description": "Narrative and storytelling elements",
      "importance": "medium",
      "range": [0.0, 1.0]
    },
    "active_voice_ratio": {
      "weight": 0.10,
      "description": "Active vs passive voice usage",
      "importance": "low",
      "range": [0.0, 1.0]
    }
  },
  "deployment": {
    "deployment_environment": "production",
    "api_version": "v1",
    "endpoint": "/hrf/predict",
    "scaling": "horizontal",
    "monitoring": true,
    "logging": true,
    "cache_enabled": true,
    "cache_ttl": 3600
  },
  "maintenance": {
    "retraining_interval": "monthly",
    "performance_monitoring": true,
    "drift_detection": true,
    "backup_frequency": "daily",
    "version_control": true
  },
  "limitations": {
    "max_input_length": 100000,
    "supported_languages": ["en"],
    "content_types": ["text", "markdown"],
    "edge_cases": ["very_short_text", "very_long_text", "non_english_text"],
    "known_biases": ["english_language_bias", "formal_content_preference"]
  },
  "usage_guidelines": {
    "recommended_use_cases": [
      "content_quality_assessment",
      "engagement_prediction",
      "style_consistency_checking",
      "profile_matching"
    ],
    "input_requirements": [
      "minimum_50_characters",
      "utf-8_encoding",
      "text_format_only"
    ],
    "output_interpretation": {
      "score_range": "0.0 to 1.0",
      "higher_better": true,
      "threshold_good": 0.7,
      "threshold_excellent": 0.85
    }
  },
  "compatibility": {
    "resonanceos_version": "v6.0.0+",
    "python_version": "3.8+",
    "dependencies": [],
    "external_apis": [],
    "hardware_requirements": "minimal",
    "memory_requirement_mb": 64
  },
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2026-03-09",
      "changes": [
        "Initial release",
        "Statistical model implementation",
        "8-dimensional HRV support",
        "Production deployment ready"
      ]
    }
  ],
  "contacts": {
    "primary_contact": "ResonanceOS Development Team",
    "technical_contact": "AI Engineering Team",
    "support_contact": "support@resonanceos.ai"
  }
}
